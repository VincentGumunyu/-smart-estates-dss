# Save as ".env" next to ai_api.py (same folder). One line, no spaces around =, no quotes needed.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-full-key-here

# Optional: default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# If 8765 is already in use, pick another port for BOTH terminals (example 8766):
#   $env:AI_API_PORT="8766"
#   python ai_api.py
#   cd dashboard; $env:AI_API_PORT="8766"; npm run dev

# Supabase import script vars (do not commit real values)
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
